# URAP Engine — environment variables
# Copy to .env and fill in values. Never commit .env.

# Supabase (required for enrichment cache and consent ledger)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# API key auth (leave blank to run in dev/open mode)
URAP_API_KEY=

# CORS — comma-separated allowed origins (leave * for dev)
URAP_ALLOWED_ORIGINS=*

# ── Enrichment waterfall ─────────────────────────────────────────────────────
# Sign up at https://prospeo.io — free, no CC. 75 credits/month.
PROSPEO_API_KEY=

# Sign up at https://snov.io — free, no CC. 50 credits/month.
SNOV_CLIENT_ID=
SNOV_CLIENT_SECRET=

# Sign up at https://cleanlist.ai — free, 30 credits/month.
CLEANLIST_API_KEY=

# Sign up at https://hunter.io — free, no CC. 50 requests/month.
HUNTER_API_KEY=

# ── Email sending (own-domain SMTP — Sprint 3) ───────────────────────────────
SMTP2GO_API_KEY=
BREVO_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ── Voice / SMS (Sprint 5) ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
